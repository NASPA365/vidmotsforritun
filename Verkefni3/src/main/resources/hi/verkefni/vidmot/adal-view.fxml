<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" stylesheets="@CSS/ferda.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hi.verkefni.vidmot.controller.AdalController">
   <ListView fx:id="ferdirListView" prefHeight="300.0" prefWidth="600.0" stylesheets="@CSS/ferda.css" />
   <Button fx:id="skodaBtn" mnemonicParsing="false" style="-fx-background-color: lightblue;" text="Skoða" onAction="#handleSkoda" />
   <Button mnemonicParsing="false" style="-fx-background-color: lightgreen;" text="Ný ferð" />
   <Button fx:id="eydaBtn" mnemonicParsing="false" style="-fx-background-color: pink;" text="Eyða" />
   <Label text="Skilaboð" />
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="330.0" prefWidth="627.0" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="is.vidmot.controller.AdalController">
      <padding>
          <Insets bottom="10" left="10" right="10" top="10" />
      </padding>
      <children>
      <Label text="Ferðaplan">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
          <TableView fx:id="fxListiFerdir" prefHeight="200.0" prefWidth="400.0">
              <columns>
                  <TableColumn fx:id="heitiColumn" prefWidth="140.0" text="Ferð" />
                  <TableColumn fx:id="afangastadurColumn" prefWidth="98.0" text="Áfangastaður" />
                  <TableColumn fx:id="fraColumn" prefWidth="81.0" text="frá" />
                  <TableColumn fx:id="tilColumn" prefWidth="81.0" text="til" />
                  <TableColumn fx:id="verdColumn" prefWidth="90.0" text="verð" />
              </columns>
          </TableView>
          <ButtonBar prefHeight="40.0" prefWidth="200.0">
         <buttons>
            <Button fx:id="fxSkoda" mnemonicParsing="false" onAction="#onSkoda" prefHeight="25.0" prefWidth="160.0" style="-fx-background-color: lightblue; -fx-border-color: black;" text="Skoða" />
            <Button mnemonicParsing="false" onAction="#onBaetaVid" style="-fx-border-color: black; -fx-background-color: lightgreen;" text="Bæta við" />
            <Button fx:id="fxEyda" mnemonicParsing="false" onAction="#onEyda" style="-fx-background-color: pink; -fx-border-color: black;" text="Eyða" />
         </buttons>
      </ButtonBar>
      <Label fx:id="fxSkilabod" text="Veldu ferð til að skoða eða eyða">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      </children>
  </VBox>
